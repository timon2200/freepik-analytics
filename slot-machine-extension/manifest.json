{
  "manifest_version": 3,
  "name": "Casino Generator Sound (Debug)",
  "version": "1.1",
  "description": "Plays a slot machine sound with debug logs.",
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "all_frames": true
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["slot.mp3"],
      "matches": ["<all_urls>"]
    }
  ]
}